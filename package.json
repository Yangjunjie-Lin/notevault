{
  "name": "personal-notebook",
  "private": true,
  "version": "1.0.0",
  "description": "Full-stack personal notebook application built with React, FastAPI, Firebase Authentication, and Firestore.",
  "type": "module",
  "engines": {
    "node": ">=20",
    "npm": ">=10",
    "python": ">=3.12"
  },
  "keywords": [
    "react",
    "vite",
    "fastapi",
    "firebase",
    "firestore",
    "notes"
  ],
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend run build",
    "preview:frontend": "npm --prefix frontend run preview",
    "dev:backend": "uvicorn app.main:app --reload --app-dir backend",
    "install:frontend": "npm --prefix frontend install"
  }
}
