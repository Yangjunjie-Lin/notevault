# Vercel 全栈部署环境变量配置示例

# ============================================
# Firebase 后端凭证（API Serverless Functions）
# ============================================
# 将 serviceAccountKey.json 转为一行 JSON 字符串
# 命令: cat serviceAccountKey.json | python -m json.tool --compact
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project-id",...}

# ============================================
# Firebase 前端配置（React App）
# ============================================
# 从 Firebase Console → Project Settings → Your apps 获取

VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ============================================
# API 配置（可选）
# ============================================
# Vercel 部署时使用相对路径 /api
# 本地开发时可以设置为 http://localhost:8000/api
VITE_API_BASE=/api
