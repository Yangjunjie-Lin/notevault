# Vercel 全栈部署环境变量配置示例

# ============================================
# Firebase 后端凭证（API Serverless Functions）
# ============================================
# 将 serviceAccountKey.json 转为一行 JSON 字符串
# 命令: cat serviceAccountKey.json | python -m json.tool --compact
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project-id",...}

# ============================================
# Firebase 前端配置（React App）
# ============================================
# 从 Firebase Console → Project Settings → Your apps → Web app 获取

# 示例值（来自 greatunihackdemo 项目）
VITE_FIREBASE_API_KEY=AIzaSyBp2Yj1yzvbDBlI0Iu0yt75C5y6hCTu2xM
VITE_FIREBASE_AUTH_DOMAIN=greatunihackdemo.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=greatunihackdemo
VITE_FIREBASE_STORAGE_BUCKET=greatunihackdemo.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=616164585973
VITE_FIREBASE_APP_ID=1:616164585973:web:9aaadd55b5cf947d5930bc

# ============================================
# API 配置（可选）
# ============================================
# Vercel 部署时使用相对路径 /api
# 本地开发时可以设置为 http://localhost:8000/api
VITE_API_BASE=/api
