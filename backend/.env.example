# Railway 后端环境变量配置示例
# 将此文件重命名为 .env 并填入实际值

# Firebase 服务账号密钥文件路径
# 本地开发: backend/serviceAccountKey.json
# Railway部署: 上传文件后的路径，通常为 /app/serviceAccountKey.json
FIREBASE_CREDENTIALS_PATH=backend/serviceAccountKey.json

# 允许的CORS源（用逗号分隔多个域名）
# 本地开发示例
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 生产环境示例（部署后替换为你的Vercel域名）
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# 服务端口（Railway会自动设置，本地开发可选）
PORT=8000
